# ══════════════════════════════════════════════
# RouteIQ — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════

# === LLM PROVIDERS (set the ones you use) ===

# OpenRouter (default — unified gateway to 100+ models)
# Both OPENROUTER_KEY and OPENROUTER_API_KEY work
OPENROUTER_KEY=your_openrouter_key_here

# Direct providers (optional — lower latency, bypasses OpenRouter)
ANTHROPIC_API_KEY=sk-ant-...        # Claude models
OPENAI_API_KEY=sk-...               # GPT models
GOOGLE_API_KEY=AIza...              # Gemini models (or GEMINI_API_KEY)

# Ollama (local, free, private)
OLLAMA_BASE_URL=http://localhost:11434

# === ALERTS ===
ALERT_CHANNEL=none   # telegram | email | webhook | slack | none

# Telegram
ALERT_TELEGRAM_TOKEN=your_bot_token
ALERT_TELEGRAM_CHAT_ID=your_chat_id

# Webhook
ALERT_WEBHOOK_URL=https://your-service.com/hook

# Slack
ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/...

# Email
ALERT_EMAIL=you@example.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=you@gmail.com
ALERT_SMTP_PASS=your_app_password
